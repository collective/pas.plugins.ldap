<?xml version="1.0" encoding="utf-8"?>
<registry xmlns:i18n="http://xml.zope.org/namespaces/i18n"
          i18n:domain="pas.plugins.ldap"
>

  <!-- cache -->
  <record name="pas.plugins.ldap.memcached">
    <field type="plone.registry.field.TextLine">
      <title i18n:translate="">servers, delimited by space</title>
    </field>
    <value>127.0.0.1:11211</value>
  </record>

  <!-- yafowil.widget.array -->
  <record name="yafowil.widget.array.common">
    <field type="plone.registry.field.Bool">
      <title>Array widget common resources</title>
    </field>
    <value>True</value>
  </record>

  <!-- yafowil.widget.dict -->
  <record name="yafowil.widget.dict.common">
    <field type="plone.registry.field.Bool">
      <title>Dict widget common resources</title>
    </field>
    <value>True</value>
  </record>

</registry>
