<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      lang="en"
      metal:use-macro="context/@@prefs_main_template/macros/master"
      i18n:domain="pas.plugins.ldap">
<body>

<metal:block fill-slot="prefs_configlet_main">

  <h1 class="documentFirstHeading" i18n:translate="">
    LDAP / Active Directory Configuration
  </h1>

  <div>
  <p class="formHelp" i18n:translate="">
    You can configure an LDAP connection in this control panel. You can use
    a standard LDAP server or a Microsoft Active Directory server.
  </p>
  </div>
  <tal:block tal:define="state python:view.connection_test();
                         state_ok python:state[0];
                         state_msg python:state[1]">
    <div tal:attributes="class python: 'portalMessage info' if state_ok else 'portalMessage error'">
      <strong tal:content="python: 'OK' if state_ok else 'ERROR'">state</strong>:
      <span tal:content="state_msg">msg</span>
    </div>
    <p tal:condition="state_ok">
      <a href=""
         tal:attributes="href string:${context/absolute_url}/@@plone_ldapinspector"
         class="pat-plone-modal"
         i18n:translate="">
        LDAP Inspector
      </a>
    </p>
  </tal:block>

  <tal:form replace="structure python:view.render_form()" />

</metal:block>

</body>
</html>
